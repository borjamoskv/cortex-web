---
import '../styles/global.css';
import { CortexFriction } from '../lib/CortexFriction';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "CORTEX-Persist Audit Substrate - Research on Memory, Autonomous Agents, and AI Influencers." } = Astro.props;

CortexFriction.ping('Layout.astro', 'RENDER');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="selection:bg-cortex-accent selection:text-white bg-cortex-bg text-cortex-text antialiased">
    <!-- Static Noise Overlay -->
    <div class="fixed inset-0 z-[9999] pointer-events-none opacity-[0.03] mix-blend-overlay noise-texture"></div>
    
    <slot />

    <script>
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        wheelMultiplier: 1,
        touchMultiplier: 2,
        infinite: false,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  
    <!-- SOVEREIGN FOOTER -->
    <footer class="mt-32 border-t border-white/5 pt-12 pb-12 flex flex-col md:flex-row justify-between items-center gap-8 px-6 max-w-7xl mx-auto w-full">
        <div class="text-xs font-mono text-cortex-muted">
            © 2026 CORTEX PERSIST FOUNDATION. ALL INTELLECTUAL ASSETS SECURED.
        </div>
        <div class="flex flex-wrap gap-6 text-[10px] font-mono uppercase tracking-[0.2em] text-white/40">
            <a href="https://cortexpersist.com" class="hover:text-cortex-accent transition-colors">CORTEX.COM</a>
            <a href="https://cortexpersist.dev" class="hover:text-cortex-accent transition-colors">CORTEX.DEV</a>
            <a href="/" class="hover:text-cortex-accent transition-colors text-white">CORTEX.ORG</a>
            <a href="https://agents.archi" class="hover:text-cortex-accent transition-colors">AGENTS.ARCHI</a>
        </div>
    </footer>
  </body>
</html>
